# Build output directories
/os/ubd/
/os/kbd/
/image/

# Top-level packaged image artifacts
/SAT_ANYKA_130L.IMG

# Generated boot/burn artifacts
/tools/burntool/
/rootfs/rootfs/lib/modules/*
/rootfs/*.jffs2
/rootfs/*.sqsh4
/rootfs/ko/internal/lib/modules/4.4.302-cip94/kernel/
/rootfs/rootfs/
/rootfs/ko/
/os/driver/internal/lib/modules/

# Common transient files.
# Keep shipped runtime artifacts such as *.ko, deliverable metadata such as
# modules.order, and source boot scripts such as *.cmd tracked. Only ignore
# build byproducts with names/patterns typical of generated files.
.*.cmd
*.symvers
*.d
*.tmp
!rootfs/resource/etc/init.d/
!rootfs/resource/etc/init.d/**
!rootfs/rootfs/etc/init.d/
!rootfs/rootfs/etc/init.d/**

# Directory-scoped object files that are clearly sample/build leftovers.
/platform/sample/**/*.o
/rootfs/ko/external/sample/**/*.o
/os/driver_src/wifi/**/ble_host/**/*.o
/os/driver_src/wifi/**/wifi/LinuxDriver/**/*.o

# Common generated configs inside build output trees
.config
.tmp_versions/

# Large source/toolchain archives kept locally but not tracked in Git
/tools/arm-anycloud-linux-uclibcgnueabi_V1.0.05.tar.bz2
/os/driver_src/wifi/aic8800-sdk-v6.6.0.1/toolchain/gcc-arm-none-eabi-9-2019-q4-major-x86_64-linux.tar.bz2
/os/linux.tar.gz
/os/driver_src.tar.gz

# Do not commit private signing keys.
/tools/secureboot/private.pem
