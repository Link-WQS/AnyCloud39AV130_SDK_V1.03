menu "Configure the loading path of files such as firmware"

config CONFIG_FIRMWARE_BIN_PATH
	string "Configure fw bin loading path"
	default "/etc/tr5330/tr5330.bin" if WSCFG_LINUX
	default "/jffs0/tr5330.bin" if WSCFG_LITEOS

config CONFIG_FIRMWARE_WIFICALI_PATH
	string "Configure wifi cali bin loading path"
	default "/etc/tr5330/wifi_cali.bin" if WSCFG_LINUX
	default "/jffs0/wifi_cali.bin" if WSCFG_LITEOS

config CONFIG_FIRMWARE_BSLECALI_PATH
	string "Configure bsle cali bin loading path"
	default "/etc/tr5330/btc_cali.bin" if WSCFG_LINUX
	default "/jffs0/btc_cali.bin" if WSCFG_LITEOS

config CONFIG_FIRMWARE_WOW_PATH
	string "Configure wow bin loading path"
	default "/etc/tr5330/wow.bin" if WSCFG_LINUX
	default "/jffs0/wow.bin" if WSCFG_LITEOS

config CONFIG_INI_FILE_PATH
	string "Configure ini file loading path"
	default "/etc/tr5330_cfg.ini"

