
config _PRE_PLAT_SHA256SUM_CHECK
	bool "Enable upgrade package verification"
	default y
	--help--
		Verify the integrity of the upgrade package of the device bin

config WSCFG_ONEIMAGE
	bool "Enable oneimage"
	default n
	--help--
		oneimage is used to resolve number conflicts

menuconfig WSCFG_PLAT_VARIABLE_FEATRUE
	bool "Enable enhanced features"
	default y
	--help--
		Enhanced feature master switch on platform side.
		Enhanced features are features that can be turned on and off at any time.
		Generally, turning on and off these features will not cause major functional problems

if WSCFG_PLAT_VARIABLE_FEATRUE

	menuconfig WSCFG_PLAT_DIAG_LOG_OUT
		bool "Enable diag log out"
		default y
		--help--
			Platform log output master switch

	if WSCFG_PLAT_DIAG_LOG_OUT
		config CONFIG_DIAG_SUPPORT_SOCKET
			bool "Enable diag socket support"
			default y

		config CONFIG_DIAG_SUPPORT_UART
			bool "Enable diag uart support"
			default y

		config CONFIG_DIAG_SUPPORT_LOCAL_LOG
			bool "Enable diag local log support"
			default y

		config CONFIG_DFX_SUPPORT_SHELL_PROC
			bool "Enable dfx shell proc"
			default y
			depends on CONFIG_DIAG_SUPPORT_SOCKET
	endif

	config CONFIG_PLAT_SUPPORT_DFR
		bool "Enable Plat DFR"
		default y
		depends on WSCFG_LINUX

	config CONFIG_PLAT_DFR_OUTPUT_PATH
		string "Dfr Output Path, The Path Must Exist, Example : '/etc/tr5330' "
		default "/etc/tr5330"
		depends on CONFIG_PLAT_SUPPORT_DFR
		--help--
			dfr output path, the path must exist, example : '/etc/tr5330'

	config CONFIG_HCC_SUPPORT_TEST
		bool "Enable Plat Hcc Test"
		default y

	config CONFIG_HCC_ERROR_PRINT
		bool "Enable Plat Hcc Error Print"
		default y
endif

