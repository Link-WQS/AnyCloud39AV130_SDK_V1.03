--- config/aic8800m40/target_ble_wifi_fhostif/build_ble_wifi_fhostif_case.sh
+++ config/aic8800m40/target_ble_wifi_fhostif/build_ble_wifi_fhostif_case.sh
@@ -36,8 +36,8 @@ done
 python ../../../tools/scons.py -u . PRODUCT=host-wb PLF=aic8800m40 BT=armgcc_4_8 BUILD_CMD="$0 $*" AON=off \
         TGT_MODE=ble_wifi_fhostif \
         BT_BLE=on BT_AUDIO=off APPS=on BLE_ONLY=on BT_USER=on TGTNAME=ble_wifi_fhostif \
-        BLE_DFT_STATE=adv BLE_APP_AUDTRANSMIT=none BLE_APP_SMARTCONFIG=on BLE_APP_HID=off\
+        BLE_DFT_STATE=adv BLE_APP_AUDTRANSMIT=none BLE_APP_SMARTCONFIG=on BLE_APP_HID=off BLE_APP_UDF=none \
         AUDIO=off UTILS=on HW_SBC=off AAC=off BT_PROMPT=off \
         SOFTAP=on PING=on IPERF=on CHKSUM=off \
         HEAP_SIZE=0x20000 WIFI_RAM_VER=on \
-        FHOST_APP=fhostif  HOSTIF=usb BAND5G=on $opt
+        FHOST_APP=fhostif  HOSTIF=sdio BAND5G=on $opt
