&mmc2 {
    bus-width = <0x4>;
    max-frequency = <50000000>;
    non-removable;
    cap-sd-highspeed;
    /* if support sdio, using cap-sdio-irq*/
    cap-sdio-irq;
    pinctrl-names = "default","idle";
    pinctrl-0 = <&mci2_pins>;//,<&wifi_en_pins>,<&wifi_rst_pins>;
    pinctrl-1 = <&mci2_idle_pins>;
    //power-pins = <&gpio XGPIO_098 1>;   //power-pins is which wifi_en_pins describes
    //rst-pins =   <&gpio XGPIO_056 1>;    //rst-pins is which wifi_rst_pins describes
    status = "okay"; 
};

&ethernet {
    pinctrl-names = "default","inner_sz18201";
    pinctrl-0 = <&ethernet_rmii_pins_inner_jl1101 &ethernet_rst_pins>;
    pinctrl-1 = <&ethernet_rmii_pins_inner_sz18201 &ethernet_rst_pins>;
    reset-gpios = <&gpio XGPIO_029 1>;
    phy-address = <1>;
    inner-phy-mode = <1>;
    status = "disable";
};

