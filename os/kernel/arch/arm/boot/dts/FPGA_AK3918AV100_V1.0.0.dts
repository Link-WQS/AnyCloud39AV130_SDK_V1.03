&uart0 {
    /*
    pinctrl-names = "default";
	pinctrl-0 = <&uart0_pins>;
    */
    status = "okay";
};

&i2c0 {
	/*
	pinctrl-names = "default";
	pinctrl-0 = <&i2c0_pins>;
	*/
	compatible = "i2c-gpio";//TODO FPGA is soft-i2c
	gpios = <&gpio 2 GPIO_ACTIVE_HIGH
		&gpio 3 GPIO_ACTIVE_HIGH
		>;

	clock-frequency = <100000>;//TODO FPGA is soft-i2c so not too high
	i2c-gpio,delay-us = <1>;
	sda-delay = <100>;
	status = "okay";
	#address-cells = <1>;
	#size-cells = <0>;

	sensor0: camera@0x30{
		compatible = "anyka,sensor0";
		reg = <0x30>;

		/*0xffff means the gpio is invalid*/
		reset-gpio = <&gpio 0 1>;
		pwdn-gpio = <&gpio 1 1>;

		port {
			sensor0_0: endpoint@0 {
				remote-endpoint = <&vi_0_0>;
			};
		};
	};
};

&vi0{
	/*
	pinctrl-names = "dvp0_12bits", "dvp0_10bits", "dvp0_8bits",
		"mipi0_2lane", "mipi0_1lane",
		"csi0_sclk", "csi1_sclk";
    pinctrl-0 = <&dvp0_12bits_pins>;
    pinctrl-1 = <&dvp0_10bits_pins>;
    pinctrl-2 = <&dvp0_8bits_pins>;
    pinctrl-3 = <&mipi0_2lane_pins>;
    pinctrl-4 = <&mipi0_1lane_pins>;
    pinctrl-5 = <&csi0_sclk_pin>;
    pinctrl-6 = <&csi1_sclk_pin>;
	*/
    status = "okay";

	port@0 {
		#address-cells = <1>;
		#size-cells = <0>;

		vi_0_0: endpoint@0 {
			reg = <0>;
			remote-endpoint = <&sensor0_0>;
		};
	};
};

&venc_bridge{
     status = "okay";
};

&cnn{
     status = "okay";
};

&venc{
     status = "okay";
};
