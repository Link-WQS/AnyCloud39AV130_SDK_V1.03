    status = "okay";
};

&adkeys {
    /*
    * poll interval: ms
    * debounce interval: ms
    */
    interval = <120>;
    debounce_interval = <20>;
    /*
    * if pressed-input = 0, input 0 when key is pressed, else input 1.
    */
    pressed-input = <0>;
    status = "okay";

    addet0 {
        unpress_min = <0>;
        unpress_max = <3200>;
        adc_index = <1>;
        adc_channel = <0>;

        key1 {
            linux,code = <102>; 
            min = <0>;
            max = <50>;
        };
    };
};

&saradc {
    pinctrl-names = "default";
    pinctrl-0 = <&saradc_pins>;

    /*
	 * SAR ADC VREF selection
     * 	0:To select HPVDD 3.3V as VREF for SAR ADC.
     * 	1:To select 3.0V generated from DDR as VREF for SAR ADC.
     */
    vref-select = <0>;

    /*
     * 0: To disable BAT voltage divider.
     * 1: To enable BAT voltage divider divided by 2.
     */
    battery-divider = <0>;

    /*
     * Sampling number
     * 	Read the sampling data for N times and then calculate the average value.
     * 	N ranges from 1 to 7.
     */
    sampling-num = <7>;
    status = "okay";
};

&encrypt{
    status = "okay"; 
};

&pwm0 {
	pinctrl-names = "default", "idle";
	pinctrl-0 = <&pwm0_pins>;
	pinctrl-1 = <&pwm0_pins_idle>;
	period-ns = <500>;
	duty-ns = <100>;
	pwm-enable = <1>;
	status = "okay";
};

&pwm1 {
	pinctrl-names = "default", "idle";
    pinctrl-0 = <&pwm1_pins>;
    pinctrl-1 = <&pwm1_pins_idle>;
	period-ns = <500>;
	duty-ns = <250>;
	pwm-enable = <1>;
	status = "disable";
};

&pwm2 {
	pinctrl-names = "default", "idle";
    pinctrl-0 = <&pwm2_pins>;
    pinctrl-1 = <&pwm2_pins_idle>;
	period-ns = <500>;
	duty-ns = <250>;
	pwm-enable = <1>;
	status = "disable";
};

&pwm3 {
	pinctrl-names = "default";
    pinctrl-0 = <&pwm3_pins>;
	period-ns = <8000>;
	duty-ns = <4000>;
