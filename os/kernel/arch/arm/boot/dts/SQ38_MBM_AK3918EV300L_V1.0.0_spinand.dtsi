    bus-width = <0x4>;
    max-frequency = <25000000>;
    cd_d3;
    cap-sd-highspeed;
    pinctrl-names = "default","idle";
    pinctrl-0 = <&mci1_pins_d3_detect_mode>,<&tf_en_pins>;
    pinctrl-1 = <&mci1_idle_pins>; 
    power-pins = <&gpio XGPIO_050 1>; 
    status = "okay"; 
};
*/

&ethernet {
    pinctrl-names = "default";
    pinctrl-0 = <&ethernet_rmii_pins &ethernet_rst_pins>;
    reset-gpios = <&gpio XGPIO_009 1>;
	phy-address = <1>;
    status = "okay";
};

&usb {
    status = "okay";
};

&spi0 {
    pinctrl-names = "default";
    pinctrl-0 = <&spiflash_pins>;
    spi-bus-frequency = <66000000>;
    /*
     * cap-spi-highspeed;
     * if defined, means high speed controller(Maximum 100M/s);
     * if not, means normal speed controller(below 50M/s)
     */
    cap-spi-highspeed;
    status = "okay";
};

&spif1 {
    /* spi flash data bus width:
    ** 1 means 1 wire mode.
    ** 2 means 2 wire mode
    ** 4 means 4 wire mode.
    ** default: 4 wire mode.
    **/
    bus-width = <4>;
    status = "okay";
};

&GD5F1GQ5UEY1G{
    status = "okay";
};

&GD5F2GQ5UEYIG{
    status = "okay";
};

&FS35ND01G{
    status = "okay";
};

&FS35ND02G{
    status = "okay";
};

&MX35LF1GE4AB{
    status = "okay";
};

&MX35LF2GE4AD{
    status = "okay";
};

&XT26G02E{
    status = "okay";
};

&GD5F1GM7UE{
    status = "okay";
};

&GD5F2GM7UE{
    status = "okay";
};

&FM25S01BI3{
    status = "okay";
};

&XT26G02C{
  status = "okay";
};

&W25N01KV{
  status = "okay";
};

&W25N02KV{
  status = "okay";
};

&HYF1GQ4UDACAE{
  status = "okay";
};

&HYF2GQ4UAACAE{
  status = "okay";
};

&HYF4GQ4UAACAE{
  status = "okay";
};

&F35SQA001G{
    status = "okay";
};

&GSS01GSAM0{
    status = "okay";
};

&DS35Q1GB{
    status = "okay";
};

&adc_dac {
    pinctrl-names = "default";
    pinctrl-0 = <&speaker_en_pins>;
    speak-gpios = <&gpio XGPIO_069 1>;
    pd-hpvcm = <1>;
    /*
    * The level of speak-gpios votage for power on audio: 0=low, 1=high
    */
    speak-gpios-en = <1>;
    status = "okay";

    dev0 {
        snd-dev = <SND_CARD_DAC_PLAYBACK>;
        snd-type = <AK_PCM_DEV_PLAYBACK>;
    };

    dev1 {
        snd-dev = <SND_CARD_ADC_CAPTURE>;
        snd-type = <AK_PCM_DEV_CAPTURE>;
    };

    dev2 {
        snd-dev = <SND_CARD_DAC_LOOPBACK>;
        snd-type = <AK_PCM_DEV_LOOPBACK>;
    };
};

&venc {
    status = "okay";
};

&venc_bridge{
     status = "okay";
};

&saradc {
    pinctrl-names = "default";
    pinctrl-0 = <&saradc_pins>;

    /*
	 * SAR ADC VREF selection
     * 	0:To select HPVDD 3.3V as VREF for SAR ADC.
     * 	1:To select 3.0V generated from DDR as VREF for SAR ADC.
     */
    vref-select = <0>;

    /*
     * Sampling number
     * 	Read the sampling data for N times and then calculate the average value.
     * 	N ranges from 1 to 7.
     */
    sampling-num = <3>;
    status = "okay";
};

&encrypt{
    status = "okay"; 
};
