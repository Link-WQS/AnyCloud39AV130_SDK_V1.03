*/

/* mmc1 card detect using cd_d3 */
/*
&mmc1 {
    pinctrl-names = "default","idle";
    pinctrl-0 = <&mci1_pins_d3_detect_mode &mmc1_power_pin>;
    pinctrl-1 = <&mmc1_pins_idle>;

	mci_id = <0x1>;  //for mmc id
    bus-width = <0x4>;
    max-frequency = <50000000>;

    cd_d3;
    // if support highspeed, using cap-sd-highspeed 
    cap-sd-highspeed; 
    //support tf card circuit enable function    
    power-pins = <&gpio 0 1>;      //power-pins is which tf_en_pins describes
    power-inverted;
    status = "okay";
};
*/
    

&ethernet {
    pinctrl-names = "default", "inner_sz18201";
	pinctrl-0 = <&ethernet_rmii0_pins_inner_jl1101 &ethernet_rmii0_rst_pins>;
	pinctrl-1 = <&ethernet_rmii0_pins_inner_sz18201 &ethernet_rmii0_rst_pins>;
    phy-reset = <&gpio 29 1>; //EVB_CBDM_SVT or EVB_CBDM_AK3918AV100P
    //phy-reset = <&gpio 24 1>;//EVB_CBDM_AK3918AV100N
	phy-address = <1>;
    inner-phy-mode = <1>;

	status = "disable";
	    
};

&uart0 {
    pinctrl-names = "default";
    pinctrl-0 = <&uart0_pins>;
    status = "okay";
};

&uart2 {
    pinctrl-names = "default";
    pinctrl-0 = <&uart2_pins>;
    status = "okay";
};

&spi0 {
    pinctrl-names = "default";
    pinctrl-0 = <&spiflash_pins>;
     /*pinctrl-names = "default";*/
     /*pinctrl-0 = <&spiflash_pins>;*/
    spi-max-frequency = <66000000>;
    /*
     * cap-spi-highspeed;
     * if defined, means high speed controller(Maximum 80M/s);
     * if not, means normal speed controller(below 60M/s)
     */
    cap-spi-highspeed;
    /* spi flash data bus width:
        ** 1 means 1 wire mode.
        ** 2 means 2 wire mode
        ** 4 means 4 wire mode.
        ** default: 4 wire mode.
        **/
    bus-width = <4>;
    mode = <3>; /* spi mode selected  */  
    status = "okay";
};

